---
import Base from '../layouts/Base.astro'
import PageBody from '../components/PageBody.astro'
---

<Base
  title="harnessed — AI coding harness package manager"
  description="Compose Skills, MCP, and Workflows in one manifest. Install proven harness packs in a single command."
  lang="en"
>
  <script is:inline>
    (function () {
      try {
        if (document.cookie.includes('harnessed_lang=')) return
        var lang = (navigator.language || '').toLowerCase()
        if (lang.startsWith('zh')) {
          location.replace('/zh-hans/')
        }
      } catch (e) {}
    })()
  </script>
  <PageBody lang="en" />
</Base>
