---
import InstallCommand from './InstallCommand.astro'
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
---

<section class="relative min-h-[52vh] flex items-center justify-center pt-10 pb-6">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(124,58,237,0.18),transparent_55%)]" aria-hidden="true"></div>
  <div class="max-w-4xl text-center mx-auto px-6">
    <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-violet-400/10 border border-violet-400/20 text-violet-300 text-xs">
      {dict.hero.versionPill}
    </span>

    <h1 class="mt-5 text-[38px] leading-[48px] font-medium text-white">
      {dict.hero.h1}
    </h1>

    <p class="mt-3 text-base font-medium text-violet-300 max-w-2xl mx-auto">
      {dict.hero.positioning}
    </p>

    <p class="mt-3 text-sm text-zinc-400 max-w-2xl mx-auto">
      {dict.hero.tagline}
    </p>

    <div class="mt-6">
      <InstallCommand />
    </div>

    <div class="mt-6 flex gap-4 justify-center flex-wrap">
      <a
        href="#quickstart"
        class="bg-violet-600 hover:bg-violet-500 text-white px-6 py-3 rounded-full font-medium transition-colors"
      >
        {dict.hero.ctaStart}
      </a>
      <a
        href="https://github.com/easyinplay/harnessed"
        class="border border-violet-400/40 hover:bg-violet-400/10 text-zinc-200 px-6 py-3 rounded-full font-medium transition-colors"
      >
        {dict.hero.ctaGitHub}
      </a>
    </div>

    <p class="mt-4 text-zinc-500 text-sm">{dict.hero.meta}</p>
  </div>
</section>
