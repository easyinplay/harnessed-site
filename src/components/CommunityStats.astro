---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">
      {dict.communityStats.heading}
    </h2>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
      {dict.communityStats.stats.map((stat) => (
        <div data-fade class="bg-[#15151D] border border-violet-400/10 rounded-xl p-8 text-center">
          <div class="text-[40px] font-medium text-white">{stat.value}</div>
          <div class="text-zinc-400 text-sm mt-2">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <div class="inline-flex gap-4 flex-wrap justify-center">
        <a
          href="https://github.com/easyinplay/harnessed/discussions"
          class="text-violet-400 hover:text-violet-300 text-sm transition-colors"
        >
          {dict.communityStats.links.discussions}
        </a>
        <a
          href="https://github.com/easyinplay/harnessed/issues"
          class="text-violet-400 hover:text-violet-300 text-sm transition-colors"
        >
          {dict.communityStats.links.issues}
        </a>
        <a
          href="https://github.com/easyinplay/harnessed/releases"
          class="text-violet-400 hover:text-violet-300 text-sm transition-colors"
        >
          {dict.communityStats.links.releases}
        </a>
      </div>
    </div>
  </div>
</section>
