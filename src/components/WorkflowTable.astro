---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
---

<section data-fade class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">
      {dict.workflowTable.heading}
    </h2>
    <p class="mt-3 text-zinc-400 text-center">
      {dict.workflowTable.subheading}
    </p>

    <div class="mt-12 rounded-xl border border-violet-400/10 overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-[#15151D]">
            <th class="text-zinc-300 text-sm font-medium px-5 py-3">{dict.workflowTable.colCommand}</th>
            <th class="text-zinc-300 text-sm font-medium px-5 py-3">{dict.workflowTable.colScope}</th>
            <th class="text-zinc-300 text-sm font-medium px-5 py-3">{dict.workflowTable.colCaps}</th>
          </tr>
        </thead>
        <tbody>
          {dict.workflowTable.rows.map((row) => (
            <tr class="border-t border-violet-400/5 bg-[#0A0A0F]/50">
              <td class="px-5 py-3 text-sm">
                <code class="text-violet-300">{row.cmd}</code>
              </td>
              <td class="px-5 py-3 text-sm text-zinc-400">{row.scope}</td>
              <td class="px-5 py-3 text-sm text-zinc-400">{row.caps}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-6 text-center">
      <a
        href="https://github.com/easyinplay/harnessed"
        class="text-violet-400 hover:text-violet-300 text-sm transition-colors inline-block"
      >
        {dict.workflowTable.githubLink}
      </a>
    </div>
  </div>
</section>
