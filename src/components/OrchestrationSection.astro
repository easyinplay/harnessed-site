---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
const { heading, subheading, tiers, wrapper, footnote } = dict.orchestration
---

<section data-fade class="py-24 bg-[#0F0F15]">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">{heading}</h2>
    <p class="mt-3 text-zinc-400 text-center max-w-2xl mx-auto">{subheading}</p>

    <!-- escalation ladder: downgrade → default → upgrade -->
    <div class="mt-14 flex flex-col md:flex-row md:items-stretch md:gap-3 gap-3">
      {
        tiers.map((tier, i) => (
          <>
            <div
              class:list={[
                'flex-1 rounded-xl p-6 flex flex-col',
                tier.tag === 'default'
                  ? 'bg-[#1A1622] border border-violet-400/40 shadow-[0_0_0_1px_rgba(167,139,250,0.15)]'
                  : 'bg-[#15151D] border border-violet-400/10',
              ]}
            >
              <span
                class:list={[
                  'self-start text-[11px] uppercase tracking-wide px-2 py-0.5 rounded-full',
                  tier.tag === 'default'
                    ? 'bg-violet-400/15 text-violet-300'
                    : 'bg-zinc-700/30 text-zinc-400',
                ]}
              >
                {tier.tag}
              </span>
              <h3 class="mt-4 text-[18px] font-medium text-white leading-snug">{tier.name}</h3>
              <p class="mt-1 text-violet-400/70 text-xs font-mono">{tier.cond}</p>
              <p class="mt-3 text-zinc-400 text-sm leading-relaxed">{tier.body}</p>
            </div>
            {i < tiers.length - 1 && (
              <div class="hidden md:flex items-center text-violet-400/40 flex-shrink-0">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 16 16"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M3 8h10M9 4l4 4-4 4"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
            )}
          </>
        ))
      }
    </div>

    <!-- orthogonal wrapper band -->
    <div
      class="mt-3 rounded-xl border border-dashed border-violet-400/25 bg-[#15151D]/50 px-6 py-4 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4"
    >
      <div class="flex items-center gap-3 flex-shrink-0">
        <span class="text-[11px] uppercase tracking-wide px-2 py-0.5 rounded-full bg-zinc-700/30 text-zinc-400">
          {wrapper.label}
        </span>
        <span class="text-white font-mono text-sm">{wrapper.name}</span>
      </div>
      <p class="text-zinc-400 text-sm leading-relaxed">{wrapper.body}</p>
    </div>

    <p class="mt-8 text-zinc-500 text-sm text-center max-w-3xl mx-auto leading-relaxed">{footnote}</p>
  </div>
</section>
