---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
const cards = [dict.whyCards.card1, dict.whyCards.card2, dict.whyCards.card3]
---

<section class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">{dict.whyCards.heading}</h2>
    <p class="mt-3 text-zinc-400 text-center">{dict.whyCards.subheading}</p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">
      <div data-fade class="bg-[#15151D] border border-violet-400/10 hover:border-violet-400/30 transition-colors rounded-xl p-7">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-violet-400 mb-5" aria-hidden="true">
          <rect x="4" y="16" width="20" height="6" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
          <rect x="4" y="8" width="20" height="6" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
          <rect x="7" y="3" width="14" height="4" rx="1.5" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        <h3 class="text-[20px] font-medium text-white leading-snug">{cards[0].title}</h3>
        <p class="mt-3 text-zinc-400 text-sm leading-relaxed">{cards[0].body}</p>
      </div>

      <div data-fade class="bg-[#15151D] border border-violet-400/10 hover:border-violet-400/30 transition-colors rounded-xl p-7">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-violet-400 mb-5" aria-hidden="true">
          <circle cx="6" cy="14" r="2.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="14" cy="6" r="2.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="22" cy="14" r="2.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="14" cy="22" r="2.5" stroke="currentColor" stroke-width="1.8"/>
          <path d="M8.5 14h4M14 8.5v4M14 16.5v3M16.5 14h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <h3 class="text-[20px] font-medium text-white leading-snug">{cards[1].title}</h3>
        <p class="mt-3 text-zinc-400 text-sm leading-relaxed">{cards[1].body}</p>
      </div>

      <div data-fade class="bg-[#15151D] border border-violet-400/10 hover:border-violet-400/30 transition-colors rounded-xl p-7">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-violet-400 mb-5" aria-hidden="true">
          <circle cx="14" cy="14" r="9.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="14" cy="14" r="4.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="14" cy="14" r="1.5" fill="currentColor"/>
        </svg>
        <h3 class="text-[20px] font-medium text-white leading-snug">{cards[2].title}</h3>
        <p class="mt-3 text-zinc-400 text-sm leading-relaxed">{cards[2].body}</p>
      </div>
    </div>
  </div>
</section>
