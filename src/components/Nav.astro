---
import { t, getLocaleFromUrl } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
const currentLocale = getLocaleFromUrl(Astro.url)
---

<header class="sticky top-9 z-40 h-16 bg-[#0A0A0F]/80 backdrop-blur-md border-b border-violet-400/10">
  <div class="max-w-6xl mx-auto px-6 h-full flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="font-semibold text-white">harnessed</span>
      <span class="bg-violet-400 size-1.5 rounded-full inline-block"></span>
    </a>
    <nav class="flex items-center gap-6">
      <a href={currentLocale === 'zh-Hans' ? '/docs/zh-hans/' : '/docs/'} class="text-sm text-zinc-400 hover:text-white transition-colors">{dict.nav.docs}</a>
      <a href="https://github.com/easyinplay/harnessed" class="text-sm text-zinc-400 hover:text-white transition-colors">{dict.nav.github}</a>
      <a href="https://www.npmjs.com/package/harnessed" class="text-sm text-zinc-400 hover:text-white transition-colors">{dict.nav.npm}</a>
      <span class="text-zinc-600 mx-1 select-none" aria-hidden="true">|</span>
      {currentLocale === 'en' ? (
        <>
          <span class="text-sm text-white font-medium">EN</span>
          <a
            href="/zh-Hans/"
            class="text-sm text-zinc-400 hover:text-violet-300 transition-colors lang-switch"
            data-locale="zh-Hans"
          >中文</a>
        </>
      ) : (
        <>
          <a
            href="/"
            class="text-sm text-zinc-400 hover:text-violet-300 transition-colors lang-switch"
            data-locale="en"
          >EN</a>
          <span class="text-sm text-white font-medium">中文</span>
        </>
      )}
    </nav>
  </div>
</header>

<script is:inline>
  document.querySelectorAll('.lang-switch').forEach(function(el) {
    el.addEventListener('click', function() {
      var locale = el.getAttribute('data-locale')
      if (locale) {
        document.cookie = 'harnessed_lang=' + locale + '; path=/; max-age=31536000; samesite=lax'
      }
    })
  })
</script>
