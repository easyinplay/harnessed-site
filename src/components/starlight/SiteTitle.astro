---
// Override Starlight's default SiteTitle to match our marketing brand
// Renders "harnessed · " with violet dot, consistent with Nav.astro
---
<a href="/" class="site-title-link">
  <span class="brand-name">harnessed</span>
  <span class="brand-dot" aria-hidden="true"></span>
  <span class="brand-suffix">docs</span>
</a>

<style>
  .site-title-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .site-title-link:hover {
    opacity: 0.85;
  }
  .brand-name {
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
    letter-spacing: -0.01em;
  }
  .brand-dot {
    display: inline-block;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background-color: #a78bfa; /* violet-400 */
    flex-shrink: 0;
  }
  .brand-suffix {
    font-size: 0.875rem;
    color: #71717a; /* zinc-500 */
    margin-left: 0.25rem;
  }
  @media (max-width: 640px) {
    .brand-suffix {
      display: none;
    }
  }
</style>
