---
import InstallCommand from './InstallCommand.astro'
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
---

<section id="quickstart" data-fade class="py-24 bg-[#0F0F15]">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">
      {dict.quickstart.heading}
    </h2>
    <p class="mt-3 text-zinc-400 text-center">
      {dict.quickstart.subheading}
    </p>

    <div class="mt-14 space-y-8">
      {dict.quickstart.steps.map((step) => (
        <div class="flex items-start gap-6">
          <div class="size-10 rounded-full bg-violet-600 text-white font-semibold flex items-center justify-center flex-shrink-0">
            {step.num}
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-[20px] font-medium text-white mb-3">{step.title}</h3>
            <InstallCommand cmd={step.cmd} />
            <p class="mt-3 text-zinc-500 text-sm">{step.caption}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
