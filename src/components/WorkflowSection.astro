---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)

const stageKeys = ['research', 'discuss', 'plan', 'task', 'verify', 'retro'] as const
const stages = stageKeys.map((key, i) => ({
  num: ['①', '②', '③', '④', '⑤', '⑥'][i],
  name: dict.workflowSection.stages[key].name,
  role: dict.workflowSection.stages[key].role,
  optional: key === 'research',
}))
---

<section data-fade class="py-24 bg-[#0F0F15]">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-[32px] leading-[42px] font-medium text-white text-center">
      {dict.workflowSection.heading}
    </h2>
    <p class="mt-3 text-zinc-400 text-center">
      {dict.workflowSection.subheading}
    </p>

    <div class="mt-14 flex flex-col md:flex-row md:gap-3 gap-3">
      {stages.map((stage, i) => (
        <>
          <div class="bg-[#15151D] border border-violet-400/20 px-4 py-3 rounded-lg flex flex-col items-center gap-1 md:flex-1 text-center">
            <span class="text-violet-400 text-xs">{stage.num}</span>
            <span class="text-zinc-200 text-sm font-medium">
              {stage.name}
              {stage.optional && <span class="text-zinc-500 text-xs ml-1">({dict.workflowSection.optional})</span>}
            </span>
            <span class="text-zinc-500 text-xs">{stage.role}</span>
          </div>
          {i < stages.length - 1 && (
            <div class="hidden md:flex items-center text-violet-400/40 flex-shrink-0">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
