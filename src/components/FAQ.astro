---
import { t } from '../i18n'
import type { Locale } from '../i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const dict = t(lang)
---

<section data-fade class="py-24 bg-[#F8F8FB]">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="text-[32px] font-medium text-center text-zinc-900">{dict.faq.heading}</h2>
    <p class="text-zinc-500 text-center mt-3">{dict.faq.subheading}</p>

    <div class="mt-12 space-y-3">
      {dict.faq.items.map((faq) => (
        <details class="bg-white border border-zinc-200 rounded-xl px-6 group">
          <summary class="py-5 cursor-pointer text-zinc-900 font-medium flex justify-between items-center list-none">
            <span>{faq.q}</span>
            <svg
              class="w-4 h-4 text-zinc-400 flex-shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <p class="pb-5 pt-0 text-zinc-600 text-sm leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
